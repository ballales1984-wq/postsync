{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-settings/main/schemas/v2.json",
  "productName": "PostSync",
  "version": "1.0.0",
  "identifier": "com.postsync.app",
  "build": {
    "frontendDist": "../out",
    "frontendDevCommand": "bun dev",
    "beforeDevCommand": "",
    "beforeBuildCommand": "bun run build && cp -r .next/static out/_next/static 2>/dev/null || true"
  },
  "app": {
    "title": "PostSync - AI Social Media",
    "windows": [
      {
        "title": "PostSync",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://api.groq.com http://localhost:11434"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
